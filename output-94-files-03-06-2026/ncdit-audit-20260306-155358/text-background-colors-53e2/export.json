          "title": "VISION AND PRIORITIES",
          "elements": [
            {
              "type": "paragraph",
              "content": [
                {
                  "text": "NCDIT is committed to fostering a culture of innovation and operational excellence with a mission of promoting a stronger government that strategically leverages technology for an equitable, prosperous, healthier and educated North Carolina.",
                  "bold": false,
                  "italic": false,
                  "underline": false,
                  "strikethrough": false,
                  "superscript": false,
                  "subscript": false,
                  "code": false,
                  "lang": null
                }
              ],
              "lang": null,
              "readingOrder": null
            },
            {
              "type": "paragraph",
              "content": [
                {
                  "text": "The department’s priorities are:",
                  "bold": false,
                  "italic": false,
