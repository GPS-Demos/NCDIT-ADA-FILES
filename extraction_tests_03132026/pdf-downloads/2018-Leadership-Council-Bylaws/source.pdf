                  <img role="presentation" aria-hidden="true" width="3840" height="1200" src="https://files.nc.gov/deq-apnep/styles/barrio_carousel_full/public/Nature-River-Cypress.JPG?VersionId=MNIbO8MvGV9YVnGXaqOAGKPBg31Bn5Y1&amp;itok=zIne1oUP" alt="" loading="lazy" />

