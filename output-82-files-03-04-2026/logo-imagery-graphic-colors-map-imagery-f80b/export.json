              ],
              "nestedList": null,
              "term": null,
              "definition": null
            },
            {
              "content": [
                {
                  "text": "Lidar acquisition could likely take 4-5 weeks depending on weather",
                  "bold": false,
                  "italic": false,
                  "underline": false,
                  "strikethrough": false,
                  "superscript": false,
                  "subscript": false,
                  "code": false,
                  "lang": null
                }
              ],
              "nestedList": null,
              "term": null,
              "definition": null
            },
            {
              "content": [
                {
                  "text": "Orthophotography data capture to begin in late January once appropriate sun angle is achieved",
