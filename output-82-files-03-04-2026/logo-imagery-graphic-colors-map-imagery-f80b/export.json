                  "italic": false,
                  "underline": false,
                  "strikethrough": false,
                  "superscript": false,
                  "subscript": false,
                  "code": false,
                  "lang": null
                }
              ],
              "nestedList": null,
              "term": null,
              "definition": null
            },
            {
              "content": [
                {
                  "text": "Acquisition for lidar running in tandem with NCEM project – teams will collect lines each day based on weather windows",
                  "bold": false,
                  "italic": false,
                  "underline": false,
                  "strikethrough": false,
                  "superscript": false,
                  "subscript": false,
                  "code": false,
                  "lang": null
