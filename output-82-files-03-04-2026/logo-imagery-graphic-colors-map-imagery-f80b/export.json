                  "italic": false,
                  "underline": false,
                  "strikethrough": false,
                  "superscript": false,
                  "subscript": false,
                  "code": false,
                  "lang": null
                }
              ],
              "nestedList": null,
              "term": null,
              "definition": null
            },
            {
              "content": [
                {
                  "text": "Lidar to be processed in blocks and delivered intermittently when data is ready",
