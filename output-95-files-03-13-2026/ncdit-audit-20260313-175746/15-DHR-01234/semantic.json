        {
          "type": "paragraph",
          "content": [
            {
              "text": "Based upon the foregoing Findings of Fact and Conclusions of Law, the undersigned makes the following:",
              "bold": false,
              "italic": false,
              "underline": false,
              "strikethrough": false,
              "superscript": false,
              "subscript": false,
              "code": false,
