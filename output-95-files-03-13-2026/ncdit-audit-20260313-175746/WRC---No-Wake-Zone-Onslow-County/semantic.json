          "title": "Impact:",
          "elements": [
            {
              "type": "paragraph",
              "content": [
                {
                  "text": "State Government: No\nLocal Government: Yes\nPrivate Impact: Minimal\nSubstantial Impact: No",
                  "bold": false,
                  "italic": false,
                  "underline": false,
                  "strikethrough": false,
                  "superscript": false,
                  "subscript": false,
                  "code": false,
