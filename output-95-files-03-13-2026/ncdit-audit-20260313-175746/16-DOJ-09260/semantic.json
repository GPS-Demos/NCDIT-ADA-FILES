          ],
          "caption": "Case Caption",
          "summary": "Table containing the parties of the case and the document title.",
          "lang": null,
          "reading_order": null
        },
        {
          "type": "paragraph",
          "content": [
            {
              "text": "On May 24, 2016, Administrative Law Judge Donald W. Overby called this case for hearing in Raleigh, North Carolina.",
              "bold": false,
              "italic": false,
              "underline": false,
              "strikethrough": false,
              "superscript": false,
