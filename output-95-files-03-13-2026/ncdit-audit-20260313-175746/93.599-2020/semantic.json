            },
            {
              "title": "H. PERIOD OF PERFORMANCE",
              "elements": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Federal grants are provided to the State for the Federal Fiscal Year October 1 through September 30. Funds are awarded to subrecipients on a State Fiscal Year July 1 through June 30.",
                      "bold": false,
                      "italic": false,
                      "underline": false,
                      "strikethrough": false,
                      "superscript": false,
                      "subscript": false,
                      "code": false,
                      "lang": null
                    }
                  ],
                  "lang": null,
                  "reading_order": null
                }
              ],
              "reading_order": 9,
              "subsections": []
            },
            {
              "title": "I. PROCUREMENT AND SUSPENSION AND DEBARMENT",
              "elements": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "All grantees that expend federal funds (received either directly from a federal agency or passed through the N. C. Department of Health and Human Services) are required to conform to federal agency codifications of the grants management common rule accessible on the Internet at ",
                      "bold": false,
                      "italic": false,
                      "underline": false,
                      "strikethrough": false,
                      "superscript": false,
                      "subscript": false,
                      "code": false,
                      "lang": null
                    },
                    {
                      "href": "http://www.whitehouse.gov/omb/",
                      "text": "http://www.whitehouse.gov/omb/",
                      "title": null,
                      "opens_new_window": true
                    },
                    {
                      "text": ".",
                      "bold": false,
                      "italic": false,
                      "underline": false,
                      "strikethrough": false,
                      "superscript": false,
                      "subscript": false,
                      "code": false,
                      "lang": null
                    }
                  ],
                  "lang": null,
                  "reading_order": null
                },
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "All grantees that expend State funds (including federal funds passed through the N. C. Department of Health and Human Services) are required to comply with the procurement standards described in the North Carolina General Statutes and the North Carolina Administrative Code, which are identified in the State of North Carolina Agency Purchasing Manual accessible on the Internet at ",
                      "bold": false,
                      "italic": false,
                      "underline": false,
                      "strikethrough": false,
                      "superscript": false,
                      "subscript": false,
                      "code": false,
                      "lang": null
                    },
                    {
                      "href": "http://www.pandc.nc.gov/documents/Procurement_Manual_5_8_2013_interactive.pdf",
                      "text": "http://www.pandc.nc.gov/documents/Procurement_Manual_5_8_2013_interactive.pdf",
                      "title": null,
                      "opens_new_window": true
                    },
                    {
                      "text": ".",
                      "bold": false,
                      "italic": false,
                      "underline": false,
                      "strikethrough": false,
                      "superscript": false,
                      "subscript": false,
                      "code": false,
                      "lang": null
                    }
                  ],
                  "lang": null,
                  "reading_order": null
                },
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Nongovernmental subrecipients shall maintain written Procurement policies that are followed in procuring the goods and services required to administer the program.",
                      "bold": false,
                      "italic": false,
                      "underline": false,
                      "strikethrough": false,
                      "superscript": false,
